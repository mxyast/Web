generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// USER & B2B PROFILES
// -----------------------------------------------------------------------------

enum Role {
  CUSTOMER
  DEALER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String?
  role          String    @default("CUSTOMER")
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  b2bProfile    B2BProfile?
  addresses     Address[]
  orders        Order[]
  reviews       Review[]
  wishlist      Wishlist[]
  cart          Cart?
  actionRequests UserActionRequest[]
}

// -----------------------------------------------------------------------------
// RATE LIMITING & SECURITY
// -----------------------------------------------------------------------------

model RateLimit {
  id        String   @id @default(cuid())
  ip        String
  action    String
  timestamp DateTime @default(now())

  @@index([ip, action, timestamp])
}

enum PriceList {
  LIST_A
  LIST_B
  LIST_C
  LIST_D
}

model B2BProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  companyName    String
  taxOffice      String
  taxNumber      String
  priceList      PriceList @default(LIST_A)
  creditLimit    Decimal   @db.Decimal(10, 2) @default(0)
  balance        Decimal   @db.Decimal(10, 2) @default(0)
  isApproved     Boolean   @default(false)
  documents      String[]  // URLs to tax plate, trade registry, etc.
  approvedBy     String?   // Admin User ID
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AddressType {
  BILLING
  SHIPPING
}

model Address {
  id            String      @id @default(cuid())
  userId        String
  title         String      // "Home", "Office"
  fullName      String
  phone         String
  city          String
  district      String
  addressLine   String      @db.Text
  zipCode       String?
  isDefault     Boolean     @default(false)
  type          AddressType

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  billingOrders Order[]     @relation("BillingAddress")
  shippingOrders Order[]    @relation("ShippingAddress")
}

// -----------------------------------------------------------------------------
// CATALOG: CATEGORIES, BRANDS, PRODUCTS, VARIANTS
// -----------------------------------------------------------------------------

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  parentId    String?
  imageUrl    String?
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  catalogTemplates CatalogTemplate[]
  homepageSections HomepageSection[]
}

model Brand {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  logoUrl     String?
  isActive    Boolean    @default(true)

  products    Product[]
  catalogTemplates CatalogTemplate[]
}

model Product {
  id          String     @id @default(cuid())
  brandId     String
  categoryId  String
  name        String
  slug        String     @unique
  description String     @db.Text
  isB2C       Boolean    @default(true)
  isB2B       Boolean    @default(true)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  brand       Brand      @relation(fields: [brandId], references: [id])
  category    Category   @relation(fields: [categoryId], references: [id])
  variants    Variant[]
  reviews     Review[]
  campaigns   Campaign[]
}

model Variant {
  id            String       @id @default(cuid())
  productId     String
  sku           String       @unique
  barcode       String?
  color         String?
  sizeLength    String?
  weight        Decimal?     @db.Decimal(10, 2)
  powerOutput   String?
  images        String[]
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  product       Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributes    Attribute[]
  price         Price?
  inventory     Inventory?
  orderItems    OrderItem[]
  wishlists     Wishlist[]
  cartItems     CartItem[]
}

model Attribute {
  id          String   @id @default(cuid())
  variantId   String
  key         String
  value       String
  unit        String?

  variant     Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model Campaign {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String?    @db.Text
  imageUrl    String?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean    @default(true)
  platform    Platform   @default(TYPEC)
  
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}


// -----------------------------------------------------------------------------
// PRICING & INVENTORY
// -----------------------------------------------------------------------------

model Price {
  id               String   @id @default(cuid())
  variantId        String   @unique
  retailPrice      Decimal  @db.Decimal(10, 2)
  listA            Decimal  @db.Decimal(10, 2)
  listB            Decimal  @db.Decimal(10, 2)
  listC            Decimal  @db.Decimal(10, 2)
  listD            Decimal  @db.Decimal(10, 2)
  comparePrice     Decimal? @db.Decimal(10, 2)
  currency         String   @default("TRY")
  taxRate          Decimal  @db.Decimal(5, 2) @default(20.00)
  minB2BOrderQty   Int      @default(1)

  variant          Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model Inventory {
  id              String   @id @default(cuid())
  variantId       String   @unique
  totalStock      Int      @default(0)
  b2cReserveRatio Int      @default(0) // Percentage (0-100)
  reservedQty     Int      @default(0)
  minB2BOrder     Int      @default(1)

  variant         Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// ORDERS & PAYMENTS
// -----------------------------------------------------------------------------

enum Platform {
  TYPEC
  TOPTANBOX
}

enum OrderStatus {
  // B2C Statuses
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED

  // B2B Additional Statuses
  PENDING_APPROVAL
  APPROVED
  REJECTED
  RETURN_REQUESTED
  RETURNED
}

model Order {
  id                  String       @id @default(cuid())
  userId              String
  platform            Platform
  status              OrderStatus
  subtotal            Decimal      @db.Decimal(10, 2)
  discountAmount      Decimal      @db.Decimal(10, 2) @default(0)
  discountTier        String?
  totalAmount         Decimal      @db.Decimal(10, 2)
  billingAddressId    String
  shippingAddressId   String
  shippingId          String?
  trackingNumber      String?
  notes               String?      @db.Text
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  user                User         @relation(fields: [userId], references: [id])
  billingAddress      Address      @relation("BillingAddress", fields: [billingAddressId], references: [id])
  shippingAddress     Address      @relation("ShippingAddress", fields: [shippingAddressId], references: [id])
  items               OrderItem[]
  payments            Payment[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  variantId   String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalPrice  Decimal  @db.Decimal(10, 2)
  taxAmount   Decimal  @db.Decimal(10, 2)

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant     Variant  @relation(fields: [variantId], references: [id])
}

enum PaymentMethod {
  CARD
  TRANSFER
  CARI_HESAP
}

model Payment {
  id             String        @id @default(cuid())
  orderId        String
  method         PaymentMethod
  amount         Decimal       @db.Decimal(10, 2)
  status         String
  providerRef    String?
  installments   Int           @default(1)
  receiptUrl     String?
  createdAt      DateTime      @default(now())

  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// -----------------------------------------------------------------------------
// CART & DISCOUNTS
// -----------------------------------------------------------------------------

model Cart {
  id          String     @id @default(cuid())
  userId      String     @unique
  platform    Platform
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       CartItem[]
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  variantId   String
  quantity    Int
  addedAt     DateTime @default(now())

  cart        Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant     Variant  @relation(fields: [variantId], references: [id])
}

model CartDiscountTier {
  id              String   @id @default(cuid())
  platform        Platform @default(TOPTANBOX)
  minAmount       Decimal  @db.Decimal(10, 2)
  discountPercent Decimal  @db.Decimal(5, 2)
  label           String
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String   // 'PERCENT' | 'FIXED'
  value       Decimal  @db.Decimal(10, 2)
  minAmount   Decimal? @db.Decimal(10, 2)
  platform    Platform
  maxUses     Int?
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// -----------------------------------------------------------------------------
// OTHER MODULES
// -----------------------------------------------------------------------------

model Review {
  id          String   @id @default(cuid())
  productId   String
  userId      String
  rating      Int
  comment     String?  @db.Text
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Wishlist {
  id          String   @id @default(cuid())
  userId      String
  variantId   String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant     Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
}

// -----------------------------------------------------------------------------
// CATALOG ENGINE
// -----------------------------------------------------------------------------

model CatalogTemplate {
  id          String   @id @default(cuid())
  name        String
  type        String   // "Standard", "Brand Focus", "Promotion"
  description String?
  brandId     String?
  categoryId  String?
  includedProductIds String[] @default([])
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand       Brand?    @relation(fields: [brandId], references: [id])
  category    Category? @relation(fields: [categoryId], references: [id])
}

// -----------------------------------------------------------------------------
// HOMEPAGE CONTENT MANAGEMENT
// -----------------------------------------------------------------------------

model HomepageSection {
  id          String    @id @default(cuid())
  key         String    @unique  // "chargers", "audio", "smart"
  title       String
  imageUrl    String?
  defaultImageUrl String? // fallback when imageUrl is null
  categoryId  String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  isDraft     Boolean   @default(false)

  category    Category? @relation(fields: [categoryId], references: [id])
}

model HomepageBanner {
  id              String   @id @default(cuid())
  badge           String   @default("BASEUS EXCLUSIVE")
  title           String   @default("\u015eARJIN GELECEˆ")
  titleHighlight  String   @default("GAn5 PRO.")
  description     String   @default("Baseus'un en yeni nesil GaN teknolojisi ile cihazlarınızı daha hızlı ve güvenli şarj edin.")
  buttonText      String   @default("LANSMAN ÜRÜNLERİ")
  buttonUrl       String   @default("/products")
  imageUrl        String?
  isActive        Boolean  @default(true)
  isDraft         Boolean  @default(false)
}

enum ActionStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserActionRequest {
  id          String       @id @default(cuid())
  userId      String
  actionType  String       // e.g. "LOGIN_ATTEMPT", "ORDER_ATTEMPT", "PAGE_ACCESS"
  description String       @db.Text
  status      ActionStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  key   String @id
  value String @db.Text
}

model RoleDefinition {
  name        String   @id // e.g. "ADMIN", "SUPPORT", "DEALER"
  description String?
  permissions String[] // e.g. ["ACCESS_ADMIN", "MANAGE_PRODUCTS", "MANAGE_USERS", "VIEW_REPORTS"]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

